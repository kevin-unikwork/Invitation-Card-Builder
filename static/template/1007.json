      "color": "#333333",
      "x": "(w-text_w)/2",
      "y": 450,
          "animations": [
        { "preset": "fade_in", "start": 0.7 },
         { "preset": "scale_in", "start": 0.39 }
      ]
    },

    {
      "type": "text",
      "value": "RSVP",
      "font": "serif",
      "font_size": 10,
      "color": "#333333",
      "x": "(w-text_w)/2",
      "y": 476,
           "animations": [
        { "preset": "fade_in", "start": 0.75 },
         { "preset": "scale_in", "start": 0.39 }
      ]
    },

    {
      "type": "text",
      "key": "phone",
      "required": false,
      "skip_if_empty": true,
      "font": "serif",
      "font_size": 10,
      "color": "#333333",
      "x": "(w-text_w)/2",
