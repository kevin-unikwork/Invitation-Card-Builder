{
  "format": "video",
  "background": "static/template_media/White Watercolor Elegant Wedding Invitation Video.mp4",
  "output": "output/invitation-demo.mp4",
  "width": 396,
  "height": 558,
  "fps": 60,
  "duration": 5,

  "assets": {
    "fonts": {
      "serif": "static/fonts/PlayfairDisplay-Regular.ttf",
      "script": "static/fonts/GreatVibes-Regular.ttf",
      "gujarati": "static/fonts/NotoSansGujarati-VariableFont_wdth,wght.ttf"
    }
  },
  "animation_presets": {
    "fade_in": {
      "property": "opacity",
      "from": 0,
      "to": 1,
      "duration": 0.45,
      "easing": "ease-out"
    },
    "fade_out": {
      "property": "opacity",
      "from": 1,
      "to": 0,
      "duration": 0.5,
      "easing": "ease-in"
    },
      "scale_in": {
        "property": "scale",
        "from": 0.90,
        "to": 1.1,
        "duration": 3.5,
        "easing": "easeOutCubic"
      }
  },

  "global_animations": [
    {
      "preset": "fade_out",
      "start": 4,
      "targets": "all"
    }
  ],

  "layers": [

    {
      "type": "text",
      "value": "TOGETHER",
      "font": "serif",
      "font_size": 8,
      "color": "#444444",
      "x": "(w-text_w)/2",
      "y": 90,
      "animations": [
        { "preset": "fade_in", "start": 0.5 },
        { "preset": "scale_in", "start": 0.32 }
      ]
    },

    {
      "type": "text",
      "value": "WITH OUR FAMILIES",
      "font": "serif",
      "font_size": 8,
      "color": "#444444",
      "x": "(w-text_w)/2",
      "y": 112,
     "animations": [
        { "preset": "fade_in", "start": 0.5 }
      ]
    },

    {
      "type": "text",
      "key": "personName",
      "required": true,
      "font": "gujarati",
      "font_size": 25,
      "color": "#5f84a2",
      "x": "(w-text_w)/2",
      "y": 150,
          "animations": [
        { "preset": "fade_in", "start": 0.55 },
         { "preset": "scale_in", "start": 0.39 }
      ]
    },

    {
      "type": "text",
      "value": "&",
      "font": "script",
      "font_size": 25,
      "color": "#5f84a2",
      "x": "(w-text_w)/2",
      "y": 195,
           "animations": [
        { "preset": "fade_in", "start": 0.55 },
         { "preset": "scale_in", "start": 0.39 }
      ]
    },

    {
      "type": "text",
      "key": "partnerName",
      "required": true,
      "font": "gujarati",
      "font_size": 25,
      "color": "#5f84a2",
      "x": "(w-text_w)/2",
      "y": 245,
           "animations": [
        { "preset": "fade_in", "start": 0.55 },
         { "preset": "scale_in", "start": 0.39 }
      ]
    },

    {
      "type": "text",
      "value": "INVITE YOU TO OUR WEDDING",
      "font": "serif",
      "font_size": 8,
      "color": "#444444",
      "x": "(w-text_w)/2",
      "y": 300,
           "animations": [
        { "preset": "fade_in", "start": 0.60 },
