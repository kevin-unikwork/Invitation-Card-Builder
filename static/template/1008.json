{
  "format": "video",
  "background": "static/template_media/Pink Floral Modern Wedding Invitation.mp4",
  "output": "output/pink-floral-invitation.mp4",
  "width": 396,
  "height": 558,
  "fps": 30,
  "duration": 6,
  "assets": {
    "fonts": {
      "serif": "static/fonts/PlayfairDisplay-Regular.ttf",
      "script": "static/fonts/GreatVibes-Regular.ttf",
      "modern": "static/fonts/Montserrat-Regular.ttf",
      "gujarati": "static/fonts/AnekGujarati_Expanded-Regular.ttf"
    }
  },
  "animation_presets": {
    "zoom_in": {
      "property": "scale",
      "from": 0.0,
      "to": 1.0,
      "duration": 0.8,
      "easing": "easeOutCubic"
    },
    "fade_in": {
      "property": "opacity",
      "from": 0,
      "to": 1,
      "duration": 0.6,
      "easing": "easeOutCubic"
    },
    "fade_out": {
      "property": "opacity",
      "from": 1,
      "to": 0,
      "duration": 0.5,
      "easing": "easeInCubic"
    }
  },
  "global_animations": [
    {
      "preset": "fade_out",
      "start": 5,
      "targets": "all"
    }
  ],
  "layers": [
    {
      "id": "join_us",
      "type": "text",
      "value": "JOIN US",
      "font": "serif",
      "font_size": 30,
      "color": "#4a4a4a",
      "x": "(w-text_w)/2",
      "y": 150,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 0.5
        }
      ]
    },
    {
      "id": "wedding_line",
      "type": "text",
      "value": "FOR",
      "font": "modern",
      "font_size": 14,
      "letter_spacing": 2,
      "color": "#4A4A4A",
      "x": "(w-text_w)/2 - 200",
      "y": 300,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 0.7
        },
        {
          "preset": "fade_in",
          "start": 0.7
        }
      ]
    },
    {
      "id": "wedding_line",
      "type": "text",
      "value": "THE",
      "font": "modern",
      "font_size": 14,
      "letter_spacing": 2,
      "color": "#4A4A4A",
      "x": "(w-text_w)/2 - 100",
      "y": 300,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 0.8
        },
        {
          "preset": "fade_in",
          "start": 0.8
        }
      ]
    },
    {
      "id": "wedding_line",
      "type": "text",
      "value": "WEDDING",
      "font": "modern",
      "font_size": 14,
      "letter_spacing": 2,
      "color": "#4A4A4A",
      "x": "(w-text_w)/2 + 60",
      "y": 300,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 0.9
        },
        {
          "preset": "fade_in",
          "start": 0.9
        }
      ]
    },
    {
      "id": "wedding_line",
      "type": "text",
      "value": "OF",
      "font": "modern",
      "font_size": 14,
      "letter_spacing": 2,
      "color": "#4A4A4A",
      "x": "(w-text_w)/2 + 200",
      "y": 300,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 1.0
        },
        {
          "preset": "fade_in",
          "start": 1.0
        }
      ]
    },
    {
      "id": "bride_name",
      "type": "text",
      "key": "bride_name",
      "font": "gujarati",
      "font_size": 26,
      "color": "#2f2f2f",
      "x": "(w-text_w)/2 - 150",
      "y": 1250,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 1.8
        }
      ]
    },
    {
      "id": "ampersand",
      "type": "text",
      "value": "&",
      "font": "serif",
      "font_size": 26,
      "color": "#2f2f2f",
      "x": "(w-text_w)/2",
      "y": 1250,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 2.0
        }
      ]
    },
    {
      "id": "groom_name",
      "type": "text",
      "key": "groom_name",
      "font": "gujarati",
      "font_size": 26,
      "color": "#2f2f2f",
      "x": "(w-text_w)/2 + 150",
      "y": 1250,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 2.2
        }
      ]
    },
    {
      "id": "date",
      "type": "text",
      "key": "wedding_date",
      "format": {
        "type": "date",
        "pattern": "dd MMMM yyyy"
      },
      "font": "modern",
      "font_size": 18,
      "letter_spacing": 2,
      "color": "#4a4a4a",
      "x": "(w-text_w)/2",
      "y": 1350,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 2.5
        }
      ]
    },
    {
      "id": "address",
      "type": "text",
      "key": "venue_address",
      "font": "gujarati",
      "font_size": 13,
      "letter_spacing": 1,
      "color": "#6b6b6b",
      "x": "(w-text_w)/2",
      "y": 1450,
      "animations": [
        {
          "preset": "zoom_in",
          "start": 2.8
        }
      ]
    }
  ]
}